# Copie este arquivo para backend/.env e preencha com seus valores reais.
PORT=4000
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=curso
DATABASE_USER=postgres
DATABASE_PASSWORD=troque-esta-senha
DATABASE_SSL=disable
# Opcional: use a URL completa do banco em vez dos campos acima
DATABASE_URL=postgres://postgres:troque-esta-senha@localhost:5432/curso?sslmode=disable
SESSION_SECRET=troque-este-segredo
AI_CONFIG_SECRET=troque-este-segredo-ai
PIXIAN_USERNAME=coloque-seu-usuario-pixian-aqui
PIXIAN_PASSWORD=coloque-sua-senha-pixian-aqui
PIXIAN_TEST_MODE=true